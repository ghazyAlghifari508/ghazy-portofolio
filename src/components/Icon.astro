const { name, size = 24, class: className = "", title } = Astro.props;
const paths = ICONS[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={title ? undefined : "true"}
  role={title ? "img" : undefined}
  set:html={(title ? `<title>${title}</title>` : "") + paths}
/>
