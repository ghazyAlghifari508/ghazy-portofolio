---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const items = (await getCollection("experience")).sort((a, b) =>
  a.data.start.localeCompare(b.data.start)
);

const fullMonths = ["", "Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
const fmt = (d?: string) => {
  if (!d) return "Present";
  const parts = d.split("-");
  const y = parts[0], m = parts[1], day = parts[2];
  if (day) return `${Number(day)} ${fullMonths[Number(m)]} ${y}`;
  if (m) return `${fullMonths[Number(m)]} ${y}`;
  return y;
};
---

<BaseLayout title="Experience — Ghazy Nabil Alghifari">
  <SectionHeading
    eyebrow="Timeline"
    title="Experience"
    subtitle="Selected experiences, internships, teaching, and competition milestones. Each entry includes a photo and a short description."
  />

  <div class="space-y-14">
    {
      items.map((it, i) => (
        <article
          data-reveal
          data-reveal-delay={i * 70}
          class="grid gap-6 md:grid-cols-[1fr_1.4fr]"
        >
          <div class="overflow-hidden rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-section)]">
            {it.data.image ? (
              <img
                src={it.data.image}
                alt={`Photo: ${it.data.role}`}
                width="800"
                height="500"
                loading="lazy"
                class="max-h-60 w-full object-scale-down md:max-h-72"
              />
            ) : (
              <div class="flex h-52 w-full items-center justify-center bg-[var(--surface-section)] text-[var(--text-secondary)] md:h-56">
                <span class="text-[13px]">No photo available</span>
              </div>
            )}
          </div>

          <div class="flex flex-col justify-center">
            <p class="mb-2 text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--text-secondary)]">
              {it.data.start === it.data.end ? fmt(it.data.start) : `${fmt(it.data.start)} — ${fmt(it.data.end)}`}
            </p>
            <h2 class="text-2xl font-medium text-[var(--text-primary)]">
              {it.data.role}
            </h2>
            <p class="mt-1 text-[15px] font-medium text-[var(--text-secondary)]">
              {it.data.org}
            </p>
            <p class="mt-3 leading-relaxed text-[var(--text-secondary)]">
              {it.data.summary}
            </p>
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
