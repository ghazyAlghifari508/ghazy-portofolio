---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Icon from "../components/Icon.astro";

const email = "alghifarighazy508@gmail.com";
const socials = [
  { icon: "github", label: "GitHub", href: "https://github.com/ghazyAlghifari508", handle: "ghazyAlghifari508" },
  { icon: "linkedin", label: "LinkedIn", href: "https://www.linkedin.com/in/ghazy-alghifari-b81598386/", handle: "Ghazy Alghifari" },
  { icon: "instagram", label: "Instagram", href: "https://www.instagram.com/el_gh1farry/", handle: "@el_gh1farry" },
  { icon: "mail", label: "Email", href: `mailto:${email}`, handle: email },
] as const;
---

<BaseLayout title="Contact — Ghazy Nabil Alghifari">
  <SectionHeading
    eyebrow="Let's connect"
    title="Contact"
    subtitle="Interested in collaborating, discussing a project, or learning more about my work? Send a message and I'll get back to you."
  />

  <div class="grid gap-8 md:grid-cols-[1fr_1.2fr]">
    <div data-reveal class="space-y-3">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex min-h-14 items-center gap-4 rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-card)] px-5 transition-colors hover:bg-[var(--surface-section)]"
          >
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-electric-lime text-near-black">
              <Icon name={s.icon} size={18} />
            </span>
            <span>
              <span class="block font-medium text-[var(--text-primary)]">{s.label}</span>
              <span class="block text-sm text-[var(--text-secondary)]">{s.handle}</span>
            </span>
          </a>
        ))
      }
    </div>

    <div
      data-reveal
      data-reveal-delay="90"
      class="space-y-4 rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-card)] p-6 sm:p-8"
    >
      <p class="text-lg text-[var(--text-primary)]">
        Or email me directly at{' '}
        <a href={`mailto:${email}`} class="font-medium underline underline-offset-4 decoration-electric-lime">
          {email}
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
