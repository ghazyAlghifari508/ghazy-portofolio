---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Icon from "../components/Icon.astro";

// TODO(user): replace with your real contact details.
const email = "ghazy@example.com";
const socials = [
  { icon: "github", label: "GitHub", href: "https://github.com/", handle: "@username" },
  { icon: "linkedin", label: "LinkedIn", href: "https://linkedin.com/in/", handle: "Ghazy Nabil" },
  { icon: "mail", label: "Email", href: `mailto:${email}`, handle: email },
] as const;
---

<BaseLayout title="Contact — Ghazy Nabil Alghifari">
  <SectionHeading
    eyebrow="Let's connect"
    title="Contact"
    subtitle="Interested in collaborating, discussing a project, or learning more about my work? Send a message and I'll get back to you."
  />

  <div class="grid gap-8 md:grid-cols-[1fr_1.2fr]">
    <div data-reveal class="space-y-3">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target={s.icon === "mail" ? undefined : "_blank"}
            rel={s.icon === "mail" ? undefined : "noopener noreferrer"}
            class="flex min-h-14 items-center gap-4 rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-card)] px-5 transition-colors hover:bg-[var(--surface-section)]"
          >
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-electric-lime text-near-black">
              <Icon name={s.icon} size={18} />
            </span>
            <span>
              <span class="block font-medium text-[var(--text-primary)]">{s.label}</span>
              <span class="block text-sm text-[var(--text-secondary)]">{s.handle}</span>
            </span>
          </a>
        ))
      }
    </div>

    <form
      data-reveal
      data-reveal-delay="90"
      class="space-y-4 rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-card)] p-6 sm:p-8"
      action={`mailto:${email}`}
      method="post"
      enctype="text/plain"
    >
      <div>
        <label for="name" class="mb-1.5 block text-sm font-medium text-[var(--text-primary)]">
          Name
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class="min-h-12 w-full rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-ground)] px-4 text-[var(--text-primary)] outline-none focus:border-near-black dark:focus:border-electric-lime"
        />
      </div>
      <div>
        <label for="email" class="mb-1.5 block text-sm font-medium text-[var(--text-primary)]">
          Email
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="min-h-12 w-full rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-ground)] px-4 text-[var(--text-primary)] outline-none focus:border-near-black dark:focus:border-electric-lime"
        />
      </div>
      <div>
        <label for="message" class="mb-1.5 block text-sm font-medium text-[var(--text-primary)]">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full rounded-[var(--radius-card)] border border-[var(--border-subtle)] bg-[var(--surface-ground)] p-4 text-[var(--text-primary)] outline-none focus:border-near-black dark:focus:border-electric-lime"
        ></textarea>
      </div>
      <button
        type="submit"
        class="inline-flex min-h-12 items-center gap-2 rounded-[var(--radius-card)] bg-electric-lime px-6 font-medium text-near-black ring-1 ring-near-black transition-colors hover:bg-[#aef03c]"
      >
        Send Message
        <Icon name="send" size={18} />
      </button>
      <p class="text-[13px] text-[var(--text-secondary)]">
        This form currently uses a mailto fallback. Connect Formspree or a custom API when you want automatic submissions.
      </p>
    </form>
  </div>
</BaseLayout>
